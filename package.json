{
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "start:scraper": "cd packages/scraper && ts-node src/scraper.ts",
    "start:web": "pnpm --filter web-ui run dev",
    "build:web": "pnpm --filter web-ui run build",
    "build:scraper": "pnpm --filter scraper run build",
    "serve:web": "pnpm --filter web-ui run start",
    "build": "pnpm run build:web && pnpm run build:scraper"
  }
}
